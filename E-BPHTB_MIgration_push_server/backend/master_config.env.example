# =============================================================================
# Pemetaan conf.cfg/master_config.php (CodeIgniter) → backend Go (env)
# Salin ke .env di server atau set di layanan Windows; JANGAN commit password.
# Dokumen kode: internal/config/master_parity.go
# Tata letak folder server: ../SERVER_WORKSPACE_LAYOUT.md (BPHTB_BOGOR_DEV_FARRAS/E-BPHTB_MIgration)
# =============================================================================

# --- Identitas aplikasi (mirror PHP define) ---
APP_TITLE=SISTEM INFORMASI PEMERIKSAAN PAJAK BUMI DAN BANGUNAN
APP_NAME=os_bphtb_bgr
APP_CORP=SIMDADU
APP_VERSION=0.1
APP_YEAR=2019
LICENSE_TO=PEMERINTAH KABUPATEN BOGOR
LICENSE_TO_SUB=BADAN KEPEGAWAIAN DAN PENGEMBANGAN SDM
APP_TIMEZONE=Asia/Jakarta

# --- Wilayah / referensi BPHTB-PBB ---
KD_PROPINSI=32
KD_DATI2=03
SIPPBB_SP_01=800
SIPPBB_SP_02=BIDPP
SIPPBB_PP_01=973
SIPPBB_PP_02=BIDPP
KD_KANWIL=22
KD_KANTOR=13
MENU_AKSES_ID=bphtb_bgr_id
DOMAIN_BOGOR=192.168.1.210

# Upload (registrasi lampiran) — mirror SIZE_FILE_MAX
SIZE_FILE_MAX=1000000
SIZE_FILE_MAX_LABEL=1MB

# --- URL aplikasi PHP legacy (IIS / CodeIgniter) ---
# Set agar Next.js bisa menaut ke modul yang masih di PHP (registrasi, dll.)
# Contoh: http://192.168.1.50/bphtb_bogor_dev_farras/
PHP_LEGACY_BASE_URL=

# --- SQL Server produksi (BPHTB_RESTORE) — untuk integrasi MSSQL nanti ---
# Go dev saat ini memakai DATABASE_URL (Postgres). Variabel ini hanya metadata +
# kesiapan konektor; password tidak pernah dikirim ke GET /api/config.
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=

# --- Oracle PBB (NOP / SISMIOP) — mirror DB_*_PBB / SCHEMA_PBB ---
PBB_HOST=
PBB_PORT=1521
PBB_DATABASE=SIMPBB
PBB_SCHEMA=SIMPBB
PBB_USER=
PBB_PASSWORD=

# --- SMTP (kirim email dari Go) — mirror SMTP_* PHP ---
# PHP memakai ssl://smtp.googlemail.com; di Go cukup host tanpa prefix ssl://
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_UNAME=E-BPHTB KAB BOGOR

# --- Backend Go (tambahan, bukan di master_config.php) ---
# PORT=8000
# API_URL=http://127.0.0.1:8000
# DATABASE_URL=postgres://...
# CORS_ORIGINS=http://localhost:3000,http://192.168.1.50:3000
